<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#0f0f0f] text-white">
    <nav class="p-4 border-b border-gray-800"><a href="/" class="text-xl font-bold">仙人Tube</a></nav>
    <main class="flex flex-col lg:flex-row p-6 gap-6">
        <div class="flex-1">
            <div id="playerContainer" class="w-full aspect-video rounded-xl bg-black overflow-hidden">
                <!-- 初期状態はローディング。JSで再生方式を流し込みます -->
                <div class="w-full h-full flex items-center justify-center text-gray-500">Loading Player...</div>
            </div>
            <div class="mt-6">
                <% if (typeof videoInfo !== 'undefined' && videoInfo) { %>
                    <h1 class="text-xl font-bold mb-4"><%= videoInfo.title %></h1>
                    <div class="flex items-center justify-between border-b border-gray-800 pb-4 mb-4">
                        <div class="flex items-center gap-3">
                            <img src="<%= videoInfo.channelThumb %>" class="w-11 h-11 rounded-full">
                            <div>
                                <p class="font-bold"><%= videoInfo.channelName %></p>
                                <p class="text-xs text-gray-400"><%= videoInfo.subscriberCount %></p>
                            </div>
                        </div>
                        <div class="bg-[#272727] px-4 py-2 rounded-full text-sm font-bold flex items-center gap-2">
                            <span class="material-symbols-outlined text-base">thumb_up</span>
                            <%= videoInfo.likeCount %>
                        </div>
                    </div>
                <% } else { %>
                    <h2 class="text-xl font-bold">動画詳細</h2>
                <% } %>
                
                <div class="mt-8">
                    <h3 class="font-bold border-b border-gray-800 pb-2">コメント</h3>
                    <% if (typeof comments !== 'undefined' && comments.length > 0) { %>
                        <% comments.forEach(c => { %>
                            <div class="flex gap-3 my-4">
                                <img src="<%= c.authorThumb %>" class="w-10 h-10 rounded-full">
                                <div>
                                    <p class="text-xs text-gray-400"><%= c.author %></p>
                                    <p class="text-sm"><%= c.text %></p>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="text-gray-500 py-4">コメントはありません。</p>
                    <% } %>
                </div>
            </div>
        </div>
        <div class="w-full lg:w-96">
            <h3 class="font-bold mb-4">関連動画</h3>
            <% if (typeof related !== 'undefined' && related.length > 0) { %>
                <% related.forEach(rv => { %>
                    <a href="/watch?v=<%= rv.id %>" class="flex gap-2 mb-3">
                        <img src="<%= rv.thumbnail %>" class="w-40 aspect-video object-cover rounded">
                        <div class="text-xs">
                            <p class="font-bold line-clamp-2"><%= rv.title %></p>
                            <p class="text-gray-400"><%= rv.author %></p>
                        </div>
                    </a>
                <% }) %>
            <% } %>
        </div>
    </main>

    <script>
        const videoId = "<%= videoId %>";
        const streamUrl = "<%= streamUrl %>";
        const container = document.getElementById('playerContainer');
        const method = localStorage.getItem('sennin_play_method') || 'nocookie';

        async function initPlayer() {
            if (method === 'stream' && streamUrl && streamUrl !== 'null') {
                container.innerHTML = `<video src="${streamUrl}" controls autoplay class="w-full h-full"></video>`;
            } else if (method === 'education') {
                try {
                    const res = await fetch(`/watch/api/youtube/edu?v=${videoId}`);
                    const data = await res.json();
                    container.innerHTML = `<iframe src="${data.url}" class="w-full h-full" allowfullscreen allow="autoplay"></iframe>`;
                } catch (e) {
                    // 失敗時はnocookieへフォールバック
                    container.innerHTML = `<iframe src="https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1" class="w-full h-full" allowfullscreen allow="autoplay"></iframe>`;
                }
            } else {
                // nocookie
                container.innerHTML = `<iframe src="https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1" class="w-full h-full" allowfullscreen allow="autoplay"></iframe>`;
            }
        }

        initPlayer();
    </script>
</body>
</html>
