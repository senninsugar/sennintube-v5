<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#0f0f0f] text-white">
    <nav class="p-4 border-b border-gray-800"><a href="/" class="text-xl font-bold">仙人Tube</a></nav>
    <main class="flex flex-col lg:flex-row p-6 gap-6">
        <div class="flex-1">
            <!-- プレイヤーコンテナ -->
            <div id="playerContainer" class="w-full aspect-video rounded-xl bg-black overflow-hidden">
                <!-- 初期状態は既存のstream（JSで書き換えます） -->
                <video id="videoPlayer" src="<%= streamUrl %>" controls autoplay class="w-full h-full"></video>
            </div>

            <div class="mt-6">
                <h2 class="text-xl font-bold">動画詳細</h2>
                <div class="mt-8">
                    <h3 class="font-bold border-b border-gray-800 pb-2">コメント</h3>
                    <% if (typeof comments !== 'undefined' && comments.length > 0) { %>
                        <% comments.forEach(c => { %>
                            <div class="flex gap-3 my-4">
                                <img src="<%= c.authorThumb %>" class="w-10 h-10 rounded-full">
                                <div>
                                    <p class="text-xs text-gray-400"><%= c.author %></p>
                                    <p class="text-sm"><%= c.text %></p>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="text-gray-500 py-4">コメントはありません。</p>
                    <% } %>
                </div>
            </div>
        </div>
        <div class="w-full lg:w-96">
            <h3 class="font-bold mb-4">関連動画</h3>
            <% if (typeof related !== 'undefined' && related.length > 0) { %>
                <% related.forEach(rv => { %>
                    <a href="/watch?v=<%= rv.id %>" class="flex gap-2 mb-3">
                        <img src="<%= rv.thumbnail %>" class="w-40 aspect-video object-cover rounded">
                        <div class="text-xs">
                            <p class="font-bold line-clamp-2"><%= rv.title %></p>
                            <p class="text-gray-400"><%= rv.author %></p>
                        </div>
                    </a>
                <% }) %>
            <% } %>
        </div>
    </main>

    <script>
        (function() {
            // URLパラメータから動画IDを取得
            const urlParams = new URLSearchParams(window.location.search);
            const videoId = urlParams.get('v');
            
            // localStorageから設定を取得
            const playMethod = localStorage.getItem('sennin_play_method') || 'nocookie';
            const container = document.getElementById('playerContainer');
            
            if (!videoId) return;

            // 再生方法に応じたURLの生成とプレイヤーの切り替え
            if (playMethod === 'nocookie') {
                container.innerHTML = `<iframe src="https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1" class="w-full h-full" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>`;
            } 
            else if (playMethod === 'education') {
                container.innerHTML = `<iframe src="https://www.youtubeeducation.com/embed/${videoId}?autoplay=1" class="w-full h-full" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>`;
            } 
            else {
                // streamの場合は既存のvideoタグをそのまま使用（srcはEJSで注入済み）
                console.log('Playing with native stream');
            }

            // 履歴保存設定の確認
            const saveHistory = localStorage.getItem('sennin_save_history') === 'true';
            if (saveHistory) {
                // ここに履歴保存のロジック（サーバーへのfetch等）を追加可能
                console.log('History recording is enabled');
            }
        })();
    </script>
</body>
</html>
