<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
</head>
<body class="bg-[#0f0f0f] text-white">
    <nav class="p-4 border-b border-gray-800 flex items-center gap-4">
        <a href="/" class="text-xl font-bold">仙人Tube</a>
        <form action="/search" class="flex-1 max-w-xl flex bg-[#121212] border border-gray-700 rounded-full px-4 py-1">
            <input type="text" name="q" value="<%= query %>" class="bg-transparent w-full outline-none">
            <button><span class="material-symbols-outlined mt-1">search</span></button>
        </form>
    </nav>
    <main class="max-w-5xl mx-auto p-4 flex flex-col gap-6">
        <% videos.forEach(v => { %>
            <a href="/watch?v=<%= v.id %>" class="flex gap-4 group">
                <div class="w-60 flex-shrink-0">
                    <img src="<%= v.thumbnails && v.thumbnails.length > 0 ? v.thumbnails[0].url : '' %>" 
                         class="w-full aspect-video object-cover rounded-lg group-hover:opacity-80 transition-opacity" 
                         alt="<%= v.title %>">
                </div>
                <div>
                    <h3 class="text-lg font-bold line-clamp-2"><%= v.title %></h3>
                    <div class="flex items-center gap-2 mt-2">
                        <div class="w-6 h-6 bg-stone-700 rounded-full flex items-center justify-center">
                            <span class="material-symbols-outlined text-xs">person</span>
                        </div>
                        <p class="text-sm text-gray-400"><%= v.author ? v.author.name : '不明なチャンネル' %></p>
                    </div>
                </div>
            </a>
        <% }) %>
    </main>
</body>
</html>
