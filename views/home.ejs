<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title>仙人Tube</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <style>
        body { background-color: #0f0f0f; color: white; font-family: sans-serif; }
        .suggest-box { display: none; position: absolute; width: 100%; background: #222; border-radius: 0 0 12px 12px; top: 100%; z-index: 100; }
    </style>
</head>
<body class="h-screen flex flex-col items-center justify-center">
    <div class="w-full max-w-2xl px-4">
        <h1 class="text-5xl font-bold text-center mb-8 tracking-tighter">仙人Tube</h1>
        <div class="relative">
            <form action="/search" method="GET" class="flex items-center bg-[#121212] border border-gray-700 rounded-full px-5 py-3 focus-within:border-blue-500">
                <span class="material-symbols-outlined text-gray-400 mr-3">search</span>
                <input type="text" name="q" id="searchInput" autocomplete="off" placeholder="検索" class="bg-transparent w-full outline-none text-lg">
                <button type="submit" class="hidden"></button>
            </form>
            <div id="suggestBox" class="suggest-box shadow-2xl overflow-hidden border border-gray-700 border-t-0"></div>
        </div>
    </div>

    <script>
        const input = document.getElementById('searchInput');
        const box = document.getElementById('suggestBox');
        input.addEventListener('input', async () => {
            if(!input.value) { box.style.display = 'none'; return; }
            const res = await fetch(`/api/suggests?q=${input.value}`);
            const data = await res.json();
            box.innerHTML = data.map(s => `<div class="p-3 hover:bg-stone-800 cursor-pointer" onclick="location.href='/search?q=${s}'">${s}</div>`).join('');
            box.style.display = 'block';
        });
    </script>
</body>
</html>
